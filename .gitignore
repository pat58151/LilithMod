tools/
decomp/
bin/
obj/
*.zip

# Holds a copy of LilithMod.cfg, which carries the API key.
backup/

# Voice audio extracted from the games. Local training data only - these are the
# developers' assets and must never be committed or redistributed.
voice-data/

# Voice fine-tuning workspace: cloned upstream repo, extracted features, and
# 6.8 GB of checkpoints. Reproducible from the scripts; never commit it.
training/

# Local GPT-SoVITS inference stack: third-party code, a bundled Python env and
# ~2 GB of pretrained models. Runs the voice; never ours to commit.
voice-runtime/

# Local wake-word Python environment and downloaded speech models.
.wake-runtime/

# Pre-reinstall snapshots of game-folder state (configs, dumps, reference clips).
backup-preinstall-*/

# The pre-clean-slate BepInEx tree, moved out of the game folder rather than
# deleted. Contains their mod's 2 GB voice-runtime and a copy of LilithMod.cfg.
_dirty-bepinex-*/

# Local secrets: DeepSeek API key. Never commit.
.env
