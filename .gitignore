tools/
decomp/
bin/
obj/
*.zip

# Holds a copy of LilithMod.cfg, which carries the API key.
backup/

# Voice audio extracted from the games. Local training data only - these are the
# developers' assets and must never be committed or redistributed.
voice-data/

# Voice fine-tuning workspace: cloned upstream repo, extracted features, and
# 6.8 GB of checkpoints. Reproducible from the scripts; never commit it.
training/

# Local GPT-SoVITS inference stack: third-party code, a bundled Python env and
# ~2 GB of pretrained models. Runs the voice; never ours to commit.
voice-runtime/

# Local speech-input Python environment and downloaded models.
.speech-runtime/

# Pre-reinstall snapshots of game-folder state (configs, dumps, reference clips).
backup-preinstall-*/

# The pre-clean-slate BepInEx tree, moved out of the game folder rather than
# deleted. Contains their mod's 2 GB voice-runtime and a copy of LilithMod.cfg.
_dirty-bepinex-*/

# Local secrets: DeepSeek API key. Never commit.
.env

# Extracted game dialogue. Developers' content: local use only, never committed.
LilithMod/dialogue/

# Build output.
build-test*/

# Runtime logs.
runtime/*.log
runtime/__pycache__/
dist/

# Control file for the local routing hook, not project source.
.claude/routing-ack

# Python bytecode caches.
__pycache__/

# Local development hooks. Never ships; the tracked source uses partial
# methods so the build is correct with this file absent.
LilithMod/DevHooks.cs

# Staged release-zip contents for the installer build; recreated every build.
installer/payload/
dynamic-lines.ja.json

# Development records. Kept locally, not published: they are handoff notes and
# solved-problem archives, carry this machine's absolute paths, and
# DIALOGUE-LOCATIONS.md maps the game developers' own content.
HANDOFF.md
DIALOGUE-LOCATIONS.md
INSTALLER-HANDOFF.md
INSTALLER-DONE.md
PROBLEM.md
